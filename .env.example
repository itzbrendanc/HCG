# Vite only exposes environment variables prefixed with `VITE_` to the frontend build.
# Add real values in `.env` locally, and in Vercel under Project Settings → Environment Variables.

# Example (optional): set a public site URL for future integrations.
# VITE_PUBLIC_SITE_URL="https://hcg.example"

# Example (optional): a public mode flag for future form routing.
# VITE_FORM_MODE="local"
